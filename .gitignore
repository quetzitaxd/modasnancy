# ============================================================
# modasnancy — .gitignore
# ============================================================

# --- Credenciales — NUNCA subir al repo
.env
**/.env
.env.*
!.env.example

# --- Docker / Datos persistentes ---
data/
*.sql.backup
backup_*.sql

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*

# --- Logs ---
logs/
*.log

# --- Certificados SSL ---
certs/
letsencrypt/
*.pem
*.key

# --- OS ---
.DS_Store
Thumbs.db

# --- Editores ---
.vscode/
*.swp
*.swo
*~

# --- Build artifacts ---
dist/
build/

# --- Infra / VPS docs ---
vps.txt

# --- Firebase credentials ---
google-services.json
GoogleService-Info.plist
modasnancy-app-firebase-adminsdk-*.json
*firebase-adminsdk*.json

# --- Android Studio IDE ---
android/.idea/misc.xml
android/.idea/deviceManager.xml
android/.idea/planningMode.xml

# --- Python / Scripts locales ---
venv/
*.pyc
__pycache__/
generate-icons.py
generate-screenshots.py
