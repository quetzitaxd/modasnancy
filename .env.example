# ============================================================
# modasnancy — Variables de entorno
# ⚠ NUNCA subas este archivo al repositorio.
# Copia este archivo a .env y rellena los valores reales.
# ============================================================

# --- Base de datos (MariaDB) --------------------------------
DB_HOST=db
DB_NAME=modasnancy_db
DB_USER=modasnancy_user
DB_PASSWORD=TU_DB_PASSWORD_AQUI
DB_ROOT_PASSWORD=TU_DB_ROOT_PASSWORD_AQUI

# --- Administración -----------------------------------------
ADMIN_USER=admin
ADMIN_PASS=TU_ADMIN_PASSWORD_AQUI

# --- Seguridad JWT ------------------------------------------
# Generar con: node -e "require('crypto').randomBytes(64).toString('hex')"
ADMIN_TOKEN_SECRET=TU_JWT_SECRET_AQUI_64_BYTES_HEX
ADMIN_TOKEN_TTL_SECONDS=28800

# --- CORS ---------------------------------------------------
# Dominios permitidos separados por comas. Dejar vacío para permitir todos.
CORS_ORIGIN=https://tudominio.com,https://www.tudominio.com

# --- General ------------------------------------------------
NODE_ENV=production
DATA_DIR=/app/data
PORT=3000
DB_ENABLED=true

# --- Branding -----------------------------------------------
BRAND_NAME=Modas Nancy
BRAND_EMAIL=soporte@tudominio.com
BRAND_PHONE=+50200000000
BRAND_CITY=Ciudad de Guatemala
BRAND_COUNTRY=Guatemala

# --- Moneda -------------------------------------------------
CURRENCY_SYMBOL=Q
CURRENCY_CODE=GTQ

# --- Envíos (Guatemala) -------------------------------------
SHIPPING_CAPITAL_COST=25
SHIPPING_CAPITAL_FREE_THRESHOLD=500
SHIPPING_DEPARTMENT_COST=40
SHIPPING_CAPITAL_DEPARTMENTS=Guatemala

# --- CuboPago (Pasarela de Pago) ----------------------------
# Opción A: definir solo el entorno (sandbox|production)
# Opción B: definir CUBOPAGO_BASE_URL directamente
CUBOPAGO_ENVIRONMENT=sandbox
CUBOPAGO_BASE_URL=api-payment-sandbox.cubopago.com
CUBOPAGO_API_KEY=TU_API_KEY_CUBOPAGO_AQUI
